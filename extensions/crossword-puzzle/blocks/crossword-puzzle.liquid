{{ 'crossword-puzzle.css' | asset_url | stylesheet_tag }}

{%- assign accent = block.settings.accent_color -%}
<style>
  .crossword-container {
    --cw-accent: {{ accent }};
    --cw-accent-light: {{ accent | color_lighten: 30 }};
    --cw-accent-lighter: {{ accent | color_lighten: 42 }};
    --cw-accent-dark: {{ accent | color_darken: 30 }};
    --cw-accent-darker: {{ accent | color_darken: 40 }};
    --cw-accent-muted: {{ accent | color_modify: 'alpha', 0.15 }};
    --cw-accent-bg: {{ accent | color_modify: 'alpha', 0.06 }};
  }

  /* Full-width accent background on the Shopify section wrapper */
  .shopify-section:has(.crossword-container) {
    background: {{ accent | color_modify: 'alpha', 0.06 }};
  }
</style>

<div
  class="crossword-container is-collapsed"
  data-difficulty="{{ block.settings.difficulty }}"
  data-storefront-name="{{ shop.name | escape }}"
  data-shop-domain="{{ shop.permanent_domain | escape }}"
  data-accent-color="{{ accent }}"
>
  <div id="crossword-rotate-overlay" class="mobile-rotate-overlay" aria-live="polite">
    <div class="mobile-rotate-overlay-content">
      To play crossword, please rotate your phone
    </div>
  </div>

  <div id="crossword-collapsible-content" class="crossword-collapsible-content" aria-hidden="true">
    <button
      id="crossword-collapsed-cover"
      class="crossword-collapsed-cover"
      type="button"
      aria-label="Open crossword"
    >
      <span>{{ block.settings.minimized_cover_text }}</span>
    </button>

  <button
    id="crossword-close-button"
    class="crossword-close-button"
    type="button"
    aria-label="Minimize crossword"
  >
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M6 17L12 11L18 17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M6 11L12 5L18 11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <h2 class="crossword-title" id="crossword-title" role="button" tabindex="0" style="cursor: pointer;">{{ block.settings.title }}</h2>

  <!-- ===== TOOLBAR BAR ===== -->
  <div class="crossword-toolbar" id="crossword-toolbar">
    <div class="toolbar-center">
      <span id="timer-display" class="toolbar-timer">00:00</span>
      <button id="timer-pause-btn" class="toolbar-icon-btn" type="button" aria-label="Pause timer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="6" y="4" width="4" height="16" rx="1" fill="currentColor"/>
          <rect x="14" y="4" width="4" height="16" rx="1" fill="currentColor"/>
        </svg>
      </button>
    </div>
    <div class="toolbar-right">
      <button id="toolbar-help-btn" class="toolbar-icon-btn" type="button" aria-label="Get help">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
          <path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="12" cy="17" r="0.5" fill="currentColor" stroke="currentColor" stroke-width="1"/>
        </svg>
      </button>
      <button id="toolbar-settings-btn" class="toolbar-icon-btn" type="button" aria-label="Settings">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 15a3 3 0 100-6 3 3 0 000 6z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button id="submit-puzzle" class="toolbar-submit-btn" type="button">Submit</button>
    </div>
  </div>

  <div class="crossword-wrapper">
    <div class="crossword-grid-wrapper">
      <div class="crossword-grid" id="crossword-grid"></div>
      <div id="crossword-message" class="crossword-message"></div>
    </div>

    <div class="crossword-clues">
      <div class="clues-across">
        <h3>Across</h3>
        <div id="across-clues"></div>
      </div>

      <div class="clues-down">
        <h3>Down</h3>
        <div id="down-clues"></div>
      </div>
    </div>
  </div>

  </div>

  <!-- ===== HELP MODAL (outside collapsible content to avoid overflow clipping) ===== -->
  <div class="crossword-modal-overlay" id="help-modal-overlay">
    <div class="crossword-modal help-modal" id="help-modal" role="dialog" aria-labelledby="help-modal-title">
      <div class="modal-header">
        <div class="modal-header-left">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
            <path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="12" cy="17" r="0.5" fill="currentColor" stroke="currentColor" stroke-width="1"/>
          </svg>
          <h3 id="help-modal-title" class="modal-title">Get some help</h3>
        </div>
        <button class="modal-close-btn" id="help-modal-close" type="button" aria-label="Close help">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
      <div class="modal-body">
        <button class="modal-action-btn" id="how-to-play-btn" type="button">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
            <path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="12" cy="17" r="0.5" fill="currentColor" stroke="currentColor" stroke-width="1"/>
          </svg>
          How to play
        </button>
        <div class="help-instructions" id="help-instructions" style="display: none;">
          <div class="help-instructions-content">
            <p><strong>Goal:</strong> Fill in every white square with the correct letter.</p>
            <p><strong>Navigate:</strong> Click a cell to select it. Click again or double-click to toggle between Across and Down.</p>
            <p><strong>Type:</strong> Use your keyboard to enter letters. The cursor advances automatically.</p>
            <p><strong>Clues:</strong> Click a clue in the sidebar to jump to that word on the grid.</p>
            <p><strong>Check:</strong> Verify your letter, word, or the whole puzzle. Incorrect letters are shown in red.</p>
            <p><strong>Reveal:</strong> Stuck? Reveal a letter, word, or the entire puzzle. Revealed cells are marked with a blue triangle.</p>
          </div>
        </div>
        <div class="modal-section-label">Check</div>
        <button class="modal-action-btn" id="check-puzzle" type="button">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Puzzle
        </button>
        <button class="modal-action-btn" id="check-word" type="button">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Word
        </button>
        <button class="modal-action-btn" id="check-letter" type="button">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Letter
        </button>
        <div class="modal-section-label">Reveal</div>
        <button class="modal-action-btn" id="reveal-puzzle" type="button">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
          </svg>
          Puzzle
        </button>
        <button class="modal-action-btn" id="reveal-word" type="button">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
          </svg>
          Word
        </button>
        <button class="modal-action-btn" id="reveal-letter" type="button">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
          </svg>
          Letter
        </button>
        <button class="modal-action-btn modal-action-danger" id="reset-puzzle" type="button">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <polyline points="3 6 5 6 21 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Clear board
        </button>
      </div>
    </div>
  </div>

  <!-- ===== SETTINGS MODAL ===== -->
  <div class="crossword-modal-overlay" id="settings-modal-overlay">
    <div class="crossword-modal settings-modal" id="settings-modal" role="dialog" aria-labelledby="settings-modal-title">
      <div class="modal-header">
        <div class="modal-header-left">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 15a3 3 0 100-6 3 3 0 000 6z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <h3 id="settings-modal-title" class="modal-title">Settings</h3>
        </div>
        <button class="modal-close-btn" id="settings-modal-close" type="button" aria-label="Close settings">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
      <div class="modal-body">
        <div class="settings-row">
          <div class="settings-row-info">
            <span class="settings-row-label">Dark mode</span>
            <span class="settings-row-desc">Switch to a dark theme</span>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" id="setting-dark-mode">
            <span class="toggle-slider"></span>
          </label>
        </div>
        <div class="settings-row">
          <div class="settings-row-info">
            <span class="settings-row-label">Skip filled letters</span>
            <span class="settings-row-desc">Jump over cells that already have a letter when typing</span>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" id="setting-skip-filled">
            <span class="toggle-slider"></span>
          </label>
        </div>
        <div class="settings-countdown">
          <div class="settings-countdown-label">Next puzzle change in</div>
          <div class="settings-countdown-time" id="next-puzzle-countdown">--:--:--</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Custom Mobile Keyboard -->
  <div id="mobile-keyboard" class="mobile-keyboard">
    <div class="keyboard-clue-bar">
      <button class="keyboard-nav-btn" id="keyboard-prev-clue" aria-label="Previous clue">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="keyboard-clue-text" id="keyboard-clue-text">Select a cell to start</div>
      <button class="keyboard-nav-btn" id="keyboard-next-clue" aria-label="Next clue">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
    <!-- Letters keyboard (default) -->
    <div class="keyboard-keys" id="keyboard-letters">
      <div class="keyboard-row">
        <button class="keyboard-key" data-key="Q">Q</button>
        <button class="keyboard-key" data-key="W">W</button>
        <button class="keyboard-key" data-key="E">E</button>
        <button class="keyboard-key" data-key="R">R</button>
        <button class="keyboard-key" data-key="T">T</button>
        <button class="keyboard-key" data-key="Y">Y</button>
        <button class="keyboard-key" data-key="U">U</button>
        <button class="keyboard-key" data-key="I">I</button>
        <button class="keyboard-key" data-key="O">O</button>
        <button class="keyboard-key" data-key="P">P</button>
      </div>
      <div class="keyboard-row">
        <button class="keyboard-key" data-key="A">A</button>
        <button class="keyboard-key" data-key="S">S</button>
        <button class="keyboard-key" data-key="D">D</button>
        <button class="keyboard-key" data-key="F">F</button>
        <button class="keyboard-key" data-key="G">G</button>
        <button class="keyboard-key" data-key="H">H</button>
        <button class="keyboard-key" data-key="J">J</button>
        <button class="keyboard-key" data-key="K">K</button>
        <button class="keyboard-key" data-key="L">L</button>
      </div>
      <div class="keyboard-row">
        <button class="keyboard-key keyboard-key-toggle" data-key="ShowNumbers" aria-label="Show numbers and symbols">123</button>
        <button class="keyboard-key" data-key="Z">Z</button>
        <button class="keyboard-key" data-key="X">X</button>
        <button class="keyboard-key" data-key="C">C</button>
        <button class="keyboard-key" data-key="V">V</button>
        <button class="keyboard-key" data-key="B">B</button>
        <button class="keyboard-key" data-key="N">N</button>
        <button class="keyboard-key" data-key="M">M</button>
        <button class="keyboard-key keyboard-key-backspace" data-key="Backspace">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M21 4H8L2 12L8 20H21C21.5304 20 22.0391 19.7893 22.4142 19.4142C22.7893 19.0391 23 18.5304 23 18V6C23 5.46957 22.7893 4.96086 22.4142 4.58579C22.0391 4.21071 21.5304 4 21 4Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M14 10L10 14M10 10L14 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
    <!-- Numbers & symbols keyboard (hidden) -->
    <div class="keyboard-keys" id="keyboard-numbers" style="display: none;">
      <div class="keyboard-row">
        <button class="keyboard-key" data-key="1">1</button>
        <button class="keyboard-key" data-key="2">2</button>
        <button class="keyboard-key" data-key="3">3</button>
        <button class="keyboard-key" data-key="4">4</button>
        <button class="keyboard-key" data-key="5">5</button>
        <button class="keyboard-key" data-key="6">6</button>
        <button class="keyboard-key" data-key="7">7</button>
        <button class="keyboard-key" data-key="8">8</button>
        <button class="keyboard-key" data-key="9">9</button>
        <button class="keyboard-key" data-key="0">0</button>
      </div>
      <div class="keyboard-row">
        <button class="keyboard-key" data-key="@">@</button>
        <button class="keyboard-key" data-key="%">%</button>
        <button class="keyboard-key" data-key="$">$</button>
        <button class="keyboard-key" data-key="&">&amp;</button>
        <button class="keyboard-key" data-key="*">*</button>
        <button class="keyboard-key" data-key="!">!</button>
        <button class="keyboard-key" data-key="+">+</button>
        <button class="keyboard-key" data-key="=">=</button>
      </div>
      <div class="keyboard-row">
        <button class="keyboard-key keyboard-key-toggle" data-key="ShowLetters" aria-label="Show letters">abc</button>
        <button class="keyboard-key" data-key=",">,</button>
        <button class="keyboard-key" data-key=":">:</button>
        <button class="keyboard-key" data-key="/">/</button>
        <button class="keyboard-key keyboard-key-backspace" data-key="Backspace">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M21 4H8L2 12L8 20H21C21.5304 20 22.0391 19.7893 22.4142 19.4142C22.7893 19.0391 23 18.5304 23 18V6C23 5.46957 22.7893 4.96086 22.4142 4.58579C22.0391 4.21071 21.5304 4 21 4Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M14 10L10 14M10 10L14 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

<script src="{{ 'crossword-analytics.js' | asset_url }}" defer></script>
<script src="{{ 'crossword-puzzle-utils.js' | asset_url }}" defer></script>
<script src="{{ 'crossword-puzzle-data.js' | asset_url }}" defer></script>
<script src="{{ 'crossword-grid-utils.js' | asset_url }}" defer></script>
<script src="{{ 'crossword-timer.js' | asset_url }}" defer></script>
<script src="{{ 'crossword-renderer.js' | asset_url }}" defer></script>
<script src="{{ 'crossword-menus.js' | asset_url }}" defer></script>
<script src="{{ 'crossword-actions-check-reveal.js' | asset_url }}" defer></script>
<script src="{{ 'crossword-mobile-keyboard.js' | asset_url }}" defer></script>
<script src="{{ 'crossword-app.js' | asset_url }}" defer></script>
<script src="{{ 'crossword-puzzle.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Crossword Puzzle",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "info": "Leave blank for default title"
    },
    {
      "type": "text",
      "id": "minimized_cover_text",
      "label": "Minimized cover text",
      "default": "Play The Daily Crossword!"
    },
    {
      "type": "select",
      "id": "difficulty",
      "label": "Puzzle Difficulty",
      "options": [
        {
          "value": "easy",
          "label": "Easy"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "hard",
          "label": "Hard"
        }
      ],
      "default": "medium"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#4A90D9",
      "info": "Primary color for the toolbar, cell highlights, buttons, and keyboard"
    }
  ]
}
{% endschema %}
